# Chain: "sepolia" | "holesky" | "mainnet"
CHAIN=sepolia

# Alchemy RPC — https://dashboard.alchemy.com
ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Pimlico bundler API key — https://dashboard.pimlico.io
PIMLICO_API_KEY=YOUR_PIMLICO_KEY

# Your deployed ERC-1271 validator contract (becomes the Light Account owner)
ERC1271_CONTRACT_ADDRESS=0x...

# Three private keys whose combined sigs satisfy your ERC-1271 contract
SIGNER1_PRIVATE_KEY=0x...
SIGNER2_PRIVATE_KEY=0x...
SIGNER3_PRIVATE_KEY=0x...

# Set "true" to use Pimlico's verifying paymaster for sponsored gas
USE_PAYMASTER=false